# Copy to .env — never commit .env

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel

# ── Message Broker ────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://sentinel:sentinel@localhost:5672

# ── Cache / Pub-Sub ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (generate with: openssl rand -hex 32) ────────────────────────
JWT_ACCESS_SECRET=replace-with-at-least-32-char-random-secret-here
JWT_REFRESH_SECRET=replace-with-different-32-char-random-secret-here
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY_DAYS=30

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create one at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_REDIRECT_URI=http://localhost:4001/auth/github/callback

# ── GitHub Webhooks ───────────────────────────────────────────────────────────
# Set this as the secret when configuring GitHub Webhooks for your org
GITHUB_WEBHOOK_SECRET=your-webhook-secret-change-this

# ── Service URLs (for local dev, use defaults) ────────────────────────────────
AUTH_SERVICE_URL=http://localhost:4001
INGESTION_SERVICE_URL=http://localhost:4002
ORCHESTRATOR_URL=http://localhost:4003
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
